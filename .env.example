# ─── Accounting System — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in all required values.
# NEVER commit .env to source control.
#
# Required fields are marked with [REQUIRED].
# Fields with defaults can be left as-is for development.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=accounting_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD   # [REQUIRED] — no default

# ── JWT Authentication ────────────────────────────────────────────────────────
# Must be at least 32 characters. Use: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG   # [REQUIRED]
JWT_ISSUER=accounting-api
JWT_AUDIENCE=accounting-client
ACCESS_TOKEN_MINUTES=60

# ── Admin Seed User ───────────────────────────────────────────────────────────
# Created on first startup if no admin user exists.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com              # [REQUIRED]
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD      # [REQUIRED]

# ── CORS ──────────────────────────────────────────────────────────────────────
# The origin of the frontend as seen by the browser.
FRONTEND_ORIGIN=https://yourdomain.com        # [REQUIRED in production]

# ── Ports ─────────────────────────────────────────────────────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=80

# ── pgAdmin (dev profile only) ────────────────────────────────────────────────
# Start with: docker compose --profile dev up -d
PGADMIN_EMAIL=admin@accounting.local
PGADMIN_PASSWORD=CHANGE_ME

